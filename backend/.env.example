PORT=8080
NODE_ENV=development

# MongoDB Atlas → https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/spendlens?retryWrites=true&w=majority&appName=Cluster0

# Groq AI (FREE) → https://console.groq.com
# Create account → API Keys → Create Key → paste here
GROQ_API_KEY=your_groq_api_key_here

# Resend Email → https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=SpendLens <hello@yourdomain.com>

# Your React app URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100
