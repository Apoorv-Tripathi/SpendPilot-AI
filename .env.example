# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/spendlens?retryWrites=true&w=majority

# ─── Gemini AI ────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Resend Email ─────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=SpendLens <hello@yourdomain.com>

# ─── Frontend ─────────────────────────────────────────────
# Your React app URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# ─── Security ─────────────────────────────────────────────
# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100
